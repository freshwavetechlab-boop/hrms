FROM mcr.microsoft.com/dotnet/sdk:8.0 AS build
WORKDIR /src

# Copies the contents of hrms/Payroll.API into /src
COPY . .

# Look for the project file directly in the current directory
RUN dotnet restore "Payroll.API.csproj"
RUN dotnet publish "Payroll.API.csproj" -c Release -o /app/publish

FROM mcr.microsoft.com/dotnet/aspnet:8.0
WORKDIR /app
COPY --from=build /app/publish .

ENV ASPNETCORE_URLS=http://+:8080
EXPOSE 8080
ENTRYPOINT ["dotnet", "Payroll.API.dll"]
