{
  "ConnectionStrings": {
    "Default": "Server=db.example.com;Database=payroll;User ID=payroll_user;Password=CHANGE_ME;SslMode=Required;"
  },
  "Cors": {
    "AllowedOrigins": [
      "https://hr.example.com"
    ]
  },
  "Auth": {
    "CookieSecure": true
  },
  "Database": {
    "InitializeOnStartup": false
  },
  "Logging": {
    "FilePath": "logs/payroll-api-.log"
  },
  "Serilog": {
    "MinimumLevel": {
      "Default": "Information",
      "Override": {
        "Microsoft": "Warning",
        "Microsoft.AspNetCore": "Warning"
      }
    }
  }
}
